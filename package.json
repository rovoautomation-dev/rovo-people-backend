{
    "name": "hr-crm-server",
    "version": "1.0.0",
    "description": "HR CRM Backend API",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "db:up": "docker-compose up -d",
        "db:down": "docker-compose down",
        "db:clean": "docker-compose down -v",
        "db:rebuild": "docker-compose down -v && docker-compose up -d",
        "db:logs": "docker-compose logs -f mongodb"
    },
    "dependencies": {
        "axios": "^1.13.2",
        "bcryptjs": "^3.0.3",
        "cloudinary": "^1.41.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "firebase-admin": "^13.0.2",
        "form-data": "^4.0.5",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.0.3",
        "multer": "^1.4.5-lts.1",
        "multer-storage-cloudinary": "^4.0.0",
        "node-cron": "^3.0.3",
        "pdfkit": "^0.17.2",
        "socket.io": "^4.8.3"
    }
}